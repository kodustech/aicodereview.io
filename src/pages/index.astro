---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import PillarGraphic from '../components/PillarGraphic.astro';

const pillars = await getCollection('pillars');
// Sort by the 'order' field defined in the frontmatter
const sortedPillars = pillars.sort((a, b) => a.data.order - b.data.order);

const title = "AI Code Review Standards | aicodereview.io";
---

<Layout title={title}>
	<section class="max-w-3xl mb-24 lg:mb-32">
		<h1 class="text-stone-500 dark:text-zinc-500 font-mono tracking-widest uppercase text-sm mb-4">
			The 2026 Standard for AI Code Review
		</h1>
		<h2 class="text-5xl md:text-7xl font-extrabold tracking-tighter text-balance text-stone-900 dark:text-zinc-50 mb-6 font-sans leading-none">
			Diff-reading AI <br/>
			<span class="text-stone-400 dark:text-zinc-600 line-through decoration-stone-900 dark:decoration-zinc-100 decoration-4">is dead</span>.
		</h2>
		<p class="text-xl md:text-2xl text-stone-600 dark:text-zinc-400 text-pretty leading-relaxed mb-12">
			Most AI code reviewers are just expensive wrappers around a GPT prompt. They hallucinate, nitpick style over substance, and lack the context of your codebase and business logic.
		</p>
		
		<div class="border-l-4 border-stone-900 dark:border-zinc-100 pl-6 py-2 bg-stone-100/50 dark:bg-zinc-900/50">
			<p class="text-lg font-medium text-stone-800 dark:text-zinc-200 text-pretty">
				Here is the <span class="font-bold underline decoration-2 underline-offset-4">engineering baseline</span> for evaluating and implementing an AI Code Reviewer that actually ships faster, safer code.
			</p>
		</div>
	</section>

	<section id="standards" class="space-y-32">
		{sortedPillars.map((pillar) => (
			<div class="border-t border-stone-200 dark:border-zinc-800 pt-16 group">
				<h2 class="text-sm font-mono tracking-widest text-stone-500 dark:text-zinc-500 uppercase mb-4">
					[ {pillar.data.order.toString().padStart(2, '0')} ]
				</h2>
				<h3 class="text-3xl font-bold tracking-tight text-balance text-stone-900 dark:text-zinc-100 mb-8 group-hover:underline decoration-stone-300 dark:decoration-zinc-700 underline-offset-4 transition-all">
					<a href={`/standards/${pillar.id}`}>{pillar.data.title}</a>
				</h3>
				<div class="grid lg:grid-cols-12 gap-12 items-start">
					<div class="lg:col-span-7 flex flex-col justify-between h-full">
						<p class="text-pretty text-stone-600 dark:text-zinc-400 text-lg leading-relaxed mb-8">
							{pillar.data.description}
						</p>
						<div class="mt-auto">
							<a href={`/standards/${pillar.id}`} class="inline-flex items-center gap-2 text-sm font-medium text-stone-900 dark:text-zinc-100 bg-white dark:bg-zinc-950 px-5 py-3 border border-stone-300 dark:border-zinc-700 hover:bg-stone-50 dark:hover:bg-zinc-900 transition-colors">
								Read Full Standard
								<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
							</a>
						</div>
					</div>
					<div class="lg:col-span-5">
						<a href={`/standards/${pillar.id}`} class="block transition-transform hover:scale-[1.02] active:scale-[0.98]">
							<PillarGraphic order={pillar.data.order} />
						</a>
					</div>
				</div>
			</div>
		))}
	</section>
	
	<section class="mt-40 pt-16 border-t-2 border-stone-900 dark:border-zinc-100 flex flex-col items-center text-center max-w-2xl mx-auto">
		<h2 class="text-3xl font-bold tracking-tight text-balance text-stone-900 dark:text-zinc-100 mb-6">Evaluate your AI Code Review Readiness</h2>
		<p class="text-lg text-stone-600 dark:text-zinc-400 text-pretty mb-8">
			Stop paying for expensive wrappers. See how your current setup scores against the 2026 baseline.
		</p>
		<a href="/assessment" class="bg-stone-900 dark:bg-zinc-100 text-stone-50 dark:text-zinc-900 font-bold px-8 py-4 uppercase tracking-widest text-sm hover:bg-stone-800 dark:hover:bg-zinc-200 transition-colors">
			Take the Assessment [↗]
		</a>
	</section>
</Layout>
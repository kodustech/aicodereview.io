<script>
	document.querySelectorAll('.pillar-graphic').forEach((el) => {
		const htmlEl = el as HTMLElement;

		htmlEl.addEventListener('mousemove', (e) => {
			const rect = htmlEl.getBoundingClientRect();
			const x = (e.clientX - rect.left) / rect.width;
			const y = (e.clientY - rect.top) / rect.height;
			htmlEl.style.setProperty('--mx', x.toFixed(3));
			htmlEl.style.setProperty('--my', y.toFixed(3));

			// Pillar 3: track which side the mouse is on
			if (htmlEl.dataset.pillar === '3') {
				htmlEl.dataset.side = x < 0.5 ? 'left' : 'right';
			}
		});

		htmlEl.addEventListener('mouseleave', () => {
			htmlEl.style.setProperty('--mx', '0.5');
			htmlEl.style.setProperty('--my', '0.5');
			if (htmlEl.dataset.pillar === '3') {
				delete htmlEl.dataset.side;
			}
		});
	});
</script>

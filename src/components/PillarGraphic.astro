---
interface Props {
	order: number;
}

const { order } = Astro.props;
---

<div class="pillar-graphic bg-stone-100 dark:bg-zinc-900 border border-stone-200 dark:border-zinc-800 text-stone-900 dark:text-zinc-100" data-pillar={order}>
	<div class="pillar-bg dark:!opacity-[0.04]"></div>

	{order === 1 && (
		<svg viewBox="0 0 200 200" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="pillar-svg">
			{/* Multi-dimensional Context: hover connects floating sources to center */}
			{/* Source: Repo */}
			<g class="p1-source p1-s1">
				<rect x="22" y="35" width="32" height="40" rx="2" />
				<line x1="28" y1="47" x2="48" y2="47" stroke-width="0.8" opacity="0.5" />
				<line x1="28" y1="53" x2="44" y2="53" stroke-width="0.8" opacity="0.5" />
				<line x1="28" y1="59" x2="40" y2="59" stroke-width="0.8" opacity="0.5" />
			</g>
			{/* Source: Deps */}
			<g class="p1-source p1-s2">
				<rect x="148" y="28" width="32" height="40" rx="2" />
				<circle cx="164" cy="42" r="5" stroke-width="0.8" />
				<line x1="152" y1="56" x2="176" y2="56" stroke-width="0.8" opacity="0.5" />
			</g>
			{/* Source: Business */}
			<g class="p1-source p1-s3">
				<rect x="18" y="130" width="36" height="32" rx="2" />
				<path d="M 26 141 L 30 145 L 46 140" stroke-width="0.8" opacity="0.5" />
				<line x1="26" y1="151" x2="46" y2="151" stroke-width="0.8" opacity="0.5" />
			</g>
			{/* Connection lines (hidden, draw on hover) */}
			<path class="p1-line p1-l1" d="M 54 55 L 90 94" stroke-dasharray="60" stroke-dashoffset="60" />
			<path class="p1-line p1-l2" d="M 148 48 L 112 94" stroke-dasharray="60" stroke-dashoffset="60" />
			<path class="p1-line p1-l3" d="M 54 146 L 90 108" stroke-dasharray="60" stroke-dashoffset="60" />
			{/* Central node */}
			<circle class="p1-center" cx="100" cy="100" r="12" stroke-width="2" />
			<circle class="p1-center-dot" cx="100" cy="100" r="4" fill="currentColor" />
			{/* Output line */}
			<path class="p1-line p1-l4" d="M 112 108 L 150 146" stroke-dasharray="60" stroke-dashoffset="60" stroke-width="2" />
			<path class="p1-check" d="M 152 150 L 158 156 L 172 142" stroke-width="2" />
		</svg>
	)}

	{order === 2 && (
		<svg viewBox="0 0 200 200" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="pillar-svg">
			{/* Rule-Centric & Default Quiet: hover silences noise comments */}
			{/* Noise comment 1 */}
			<g class="p2-comment p2-noise p2-n1">
				<rect x="40" y="32" width="80" height="22" rx="11" />
				<text x="56" y="46" font-size="7" fill="currentColor" stroke="none" font-family="monospace">nit: indent</text>
			</g>
			{/* Noise comment 2 */}
			<g class="p2-comment p2-noise p2-n2">
				<rect x="50" y="64" width="90" height="22" rx="11" />
				<text x="62" y="78" font-size="7" fill="currentColor" stroke="none" font-family="monospace">add semicolon</text>
			</g>
			{/* Noise comment 3 */}
			<g class="p2-comment p2-noise p2-n3">
				<rect x="30" y="96" width="100" height="22" rx="11" />
				<text x="42" y="110" font-size="7" fill="currentColor" stroke="none" font-family="monospace">rename to camel</text>
			</g>
			{/* Noise comment 4 */}
			<g class="p2-comment p2-noise p2-n4">
				<rect x="55" y="128" width="76" height="22" rx="11" />
				<text x="66" y="142" font-size="7" fill="currentColor" stroke="none" font-family="monospace">missing type</text>
			</g>
			{/* Critical comment (stays) */}
			<g class="p2-comment p2-critical">
				<rect x="35" y="160" width="130" height="24" rx="4" stroke-width="2" />
				<text x="48" y="176" font-size="8" fill="currentColor" stroke="none" font-family="monospace" font-weight="bold">⚠ SQL Injection</text>
			</g>
		</svg>
	)}

	{order === 3 && (
		<svg viewBox="0 0 200 200" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="pillar-svg">
			{/* Dual-Workflow: mouse X switches between IDE (left) and PR (right) */}
			{/* IDE panel */}
			<g class="p3-panel p3-ide">
				<rect x="8" y="40" width="84" height="120" rx="4" />
				<line x1="8" y1="54" x2="92" y2="54" stroke-width="0.5" />
				<circle cx="16" cy="47" r="2" fill="currentColor" fill-opacity="0.3" />
				<circle cx="22" cy="47" r="2" fill="currentColor" fill-opacity="0.3" />
				<circle cx="28" cy="47" r="2" fill="currentColor" fill-opacity="0.3" />
				{/* Code lines */}
				<line x1="14" y1="64" x2="60" y2="64" stroke-width="0.8" opacity="0.3" />
				<line x1="14" y1="74" x2="75" y2="74" stroke-width="0.8" opacity="0.3" />
				<line x1="20" y1="84" x2="65" y2="84" stroke-width="0.8" opacity="0.3" />
				<line x1="20" y1="94" x2="55" y2="94" stroke-width="0.8" opacity="0.3" />
				<line x1="14" y1="104" x2="70" y2="104" stroke-width="0.8" opacity="0.3" />
				<line x1="14" y1="114" x2="60" y2="114" stroke-width="0.8" opacity="0.3" />
				<line x1="20" y1="124" x2="50" y2="124" stroke-width="0.8" opacity="0.3" />
				<line x1="14" y1="134" x2="65" y2="134" stroke-width="0.8" opacity="0.3" />
				<line x1="14" y1="144" x2="72" y2="144" stroke-width="0.8" opacity="0.3" />
			</g>
			{/* IDE annotations (many, verbose) */}
			<g class="p3-annotations">
				<rect class="p3-ann" x="62" y="60" width="26" height="8" rx="2" fill="currentColor" fill-opacity="0.08" />
				<rect class="p3-ann" x="58" y="80" width="28" height="8" rx="2" fill="currentColor" fill-opacity="0.08" />
				<rect class="p3-ann" x="56" y="90" width="30" height="8" rx="2" fill="currentColor" fill-opacity="0.08" />
				<rect class="p3-ann" x="64" y="110" width="22" height="8" rx="2" fill="currentColor" fill-opacity="0.08" />
				<rect class="p3-ann" x="54" y="120" width="32" height="8" rx="2" fill="currentColor" fill-opacity="0.08" />
				<rect class="p3-ann" x="60" y="140" width="26" height="8" rx="2" fill="currentColor" fill-opacity="0.08" />
			</g>
			{/* Label */}
			<text class="p3-label p3-label-ide" x="50" y="172" font-size="7" fill="currentColor" stroke="none" font-family="monospace" text-anchor="middle">LOCAL</text>
			{/* PR panel */}
			<g class="p3-panel p3-pr">
				<rect x="108" y="40" width="84" height="120" rx="4" />
				<line x1="108" y1="54" x2="192" y2="54" stroke-width="0.5" />
				<circle cx="116" cy="47" r="2" fill="currentColor" fill-opacity="0.3" />
				<path d="M 120 45 L 128 45" stroke-width="0.8" opacity="0.3" />
				{/* Diff lines */}
				<line x1="114" y1="64" x2="175" y2="64" stroke-width="0.8" opacity="0.3" />
				<line x1="114" y1="74" x2="180" y2="74" stroke-width="0.8" opacity="0.3" />
				<line x1="114" y1="84" x2="160" y2="84" stroke-width="0.8" opacity="0.3" />
				<line x1="114" y1="94" x2="175" y2="94" stroke-width="0.8" opacity="0.3" />
				<line x1="114" y1="104" x2="168" y2="104" stroke-width="0.8" opacity="0.3" />
				<line x1="114" y1="114" x2="180" y2="114" stroke-width="0.8" opacity="0.3" />
				<line x1="114" y1="124" x2="155" y2="124" stroke-width="0.8" opacity="0.3" />
				<line x1="114" y1="134" x2="170" y2="134" stroke-width="0.8" opacity="0.3" />
				<line x1="114" y1="144" x2="175" y2="144" stroke-width="0.8" opacity="0.3" />
			</g>
			{/* PR single comment (surgical) */}
			<g class="p3-surgical">
				<rect x="162" y="100" width="30" height="10" rx="3" stroke-width="2" />
				<text x="168" y="108" font-size="5" fill="currentColor" stroke="none" font-family="monospace">critical</text>
			</g>
			{/* Label */}
			<text class="p3-label p3-label-pr" x="150" y="172" font-size="7" fill="currentColor" stroke="none" font-family="monospace" text-anchor="middle">PR</text>
		</svg>
	)}

	{order === 4 && (
		<svg viewBox="0 0 200 200" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="pillar-svg">
			{/* Business Logic: hover checks off acceptance criteria */}
			{/* Ticket card */}
			<g class="p4-ticket" opacity="0.7">
				<rect x="30" y="40" width="60" height="120" rx="3" />
				<line x1="30" y1="58" x2="90" y2="58" stroke-width="0.5" />
				<text x="38" y="53" font-size="6" fill="currentColor" stroke="none" font-family="monospace" opacity="0.5">ENG-104</text>
			</g>
			{/* Checkbox items */}
			<g class="p4-checks">
				<g class="p4-check p4-c1">
					<rect x="38" y="66" width="8" height="8" rx="1" stroke-width="1" />
					<path class="p4-mark" d="M 40 70 L 42 72 L 46 68" stroke-width="1.5" />
					<line x1="50" y1="71" x2="80" y2="71" stroke-width="0.8" opacity="0.3" />
				</g>
				<g class="p4-check p4-c2">
					<rect x="38" y="86" width="8" height="8" rx="1" stroke-width="1" />
					<path class="p4-mark" d="M 40 90 L 42 92 L 46 88" stroke-width="1.5" />
					<line x1="50" y1="91" x2="76" y2="91" stroke-width="0.8" opacity="0.3" />
				</g>
				<g class="p4-check p4-c3">
					<rect x="38" y="106" width="8" height="8" rx="1" stroke-width="1" />
					<path class="p4-mark" d="M 40 110 L 42 112 L 46 108" stroke-width="1.5" />
					<line x1="50" y1="111" x2="72" y2="111" stroke-width="0.8" opacity="0.3" />
				</g>
				<g class="p4-check p4-c4">
					<rect x="38" y="126" width="8" height="8" rx="1" stroke-width="1" />
					<text class="p4-warn" x="50" y="133" font-size="6" fill="currentColor" stroke="none" font-family="monospace">⚠ gap</text>
					<line x1="50" y1="131" x2="82" y2="131" stroke-width="0.8" opacity="0.3" />
				</g>
			</g>
			{/* Connection line */}
			<path class="p4-bridge" d="M 90 100 L 110 100" stroke-dasharray="30" stroke-dashoffset="30" stroke-width="1.5" />
			{/* Code file */}
			<g class="p4-code" opacity="0.5">
				<rect x="110" y="50" width="60" height="100" rx="3" />
				<line x1="110" y1="64" x2="170" y2="64" stroke-width="0.5" />
				<text x="118" y="60" font-size="5" fill="currentColor" stroke="none" font-family="monospace" opacity="0.5">api.ts</text>
				<line x1="116" y1="74" x2="158" y2="74" stroke-width="0.8" opacity="0.2" />
				<line x1="116" y1="82" x2="162" y2="82" stroke-width="0.8" opacity="0.2" />
				<line x1="122" y1="90" x2="155" y2="90" stroke-width="0.8" opacity="0.2" />
				<line x1="122" y1="98" x2="160" y2="98" stroke-width="0.8" opacity="0.2" />
				<line x1="122" y1="106" x2="148" y2="106" stroke-width="0.8" opacity="0.2" />
				<line x1="116" y1="114" x2="162" y2="114" stroke-width="0.8" opacity="0.2" />
				<line x1="116" y1="122" x2="150" y2="122" stroke-width="0.8" opacity="0.2" />
				<line x1="116" y1="130" x2="158" y2="130" stroke-width="0.8" opacity="0.2" />
				<line x1="116" y1="138" x2="155" y2="138" stroke-width="0.8" opacity="0.2" />
			</g>
			{/* Highlight on code */}
			<rect class="p4-highlight" x="114" y="86" width="52" height="24" fill="currentColor" rx="2" />
		</svg>
	)}

	{order === 5 && (
		<svg viewBox="0 0 200 200" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="pillar-svg">
			{/* Continuous Learning: hover grows neural network connections */}
			{/* Nodes */}
			<circle class="p5-node p5-n1" cx="60" cy="60" r="6" />
			<circle class="p5-node p5-n2" cx="140" cy="50" r="6" />
			<circle class="p5-node p5-n3" cx="100" cy="100" r="8" stroke-width="2" />
			<circle class="p5-node p5-n4" cx="55" cy="140" r="6" />
			<circle class="p5-node p5-n5" cx="150" cy="130" r="6" />
			<circle class="p5-node p5-n6" cx="100" cy="160" r="5" />
			{/* Connections (draw on hover) */}
			<line class="p5-conn p5-c1" x1="66" y1="62" x2="92" y2="96" stroke-dasharray="40" stroke-dashoffset="40" />
			<line class="p5-conn p5-c2" x1="134" y1="53" x2="108" y2="96" stroke-dasharray="40" stroke-dashoffset="40" />
			<line class="p5-conn p5-c3" x1="60" y1="134" x2="94" y2="106" stroke-dasharray="40" stroke-dashoffset="40" />
			<line class="p5-conn p5-c4" x1="144" y1="128" x2="108" y2="106" stroke-dasharray="40" stroke-dashoffset="40" />
			<line class="p5-conn p5-c5" x1="100" y1="155" x2="100" y2="108" stroke-dasharray="50" stroke-dashoffset="50" />
			<line class="p5-conn p5-c6" x1="65" y1="64" x2="134" y2="50" stroke-dasharray="80" stroke-dashoffset="80" opacity="0.3" />
			<line class="p5-conn p5-c7" x1="60" y1="136" x2="146" y2="130" stroke-dasharray="90" stroke-dashoffset="90" opacity="0.3" />
			{/* Center node inner */}
			<circle class="p5-center-fill" cx="100" cy="100" r="4" fill="currentColor" />
			{/* Feedback loop arrow (bottom) */}
			<path class="p5-loop" d="M 145 140 C 155 170, 45 170, 55 140" stroke-dasharray="120" stroke-dashoffset="120" opacity="0.3" />
			<path class="p5-loop-arrow" d="M 52 145 L 55 140 L 60 145" opacity="0" />
		</svg>
	)}

	{order === 6 && (
		<svg viewBox="0 0 200 200" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="pillar-svg">
			{/* Sandbox Validation: hover runs tests */}
			{/* Terminal window */}
			<rect x="30" y="30" width="140" height="140" rx="5" stroke-width="1.5" />
			<line x1="30" y1="48" x2="170" y2="48" stroke-width="0.5" />
			<circle cx="42" cy="39" r="3" fill="currentColor" fill-opacity="0.15" />
			<circle cx="52" cy="39" r="3" fill="currentColor" fill-opacity="0.15" />
			<circle cx="62" cy="39" r="3" fill="currentColor" fill-opacity="0.15" />
			{/* Prompt (always visible) */}
			<text x="38" y="66" font-size="7" fill="currentColor" stroke="none" font-family="monospace" opacity="0.4" class="p6-prompt">$ run tests</text>
			{/* Test results (reveal on hover) */}
			<g class="p6-results">
				<text class="p6-line p6-l1" x="38" y="84" font-size="6.5" fill="currentColor" stroke="none" font-family="monospace">✓ auth.test</text>
				<text class="p6-line p6-l2" x="38" y="98" font-size="6.5" fill="currentColor" stroke="none" font-family="monospace">✓ checkout.test</text>
				<text class="p6-line p6-l3" x="38" y="112" font-size="6.5" fill="currentColor" stroke="none" font-family="monospace">✓ payment.test</text>
			</g>
			{/* Progress bar */}
			<rect x="38" y="126" width="124" height="6" rx="3" stroke-width="0.5" opacity="0.2" />
			<rect class="p6-progress" x="38" y="126" width="0" height="6" rx="3" fill="currentColor" fill-opacity="0.2" stroke="none" />
			{/* Final result */}
			<text class="p6-result" x="38" y="148" font-size="7" fill="currentColor" stroke="none" font-family="monospace" font-weight="bold">3 passed</text>
			{/* Checkmark */}
			<path class="p6-check" d="M 82 152 L 92 162 L 118 140" stroke-width="2.5" />
		</svg>
	)}

	{order === 7 && (
		<svg viewBox="0 0 200 200" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="pillar-svg">
			{/* Economic Transparency: hover reveals true cost, strikes wrapper */}
			{/* Wrapper column */}
			<g class="p7-wrapper">
				<text x="55" y="28" font-size="7" fill="currentColor" stroke="none" font-family="monospace" text-anchor="middle" opacity="0.5">Wrapper</text>
				<rect x="35" y="36" width="40" height="120" rx="3" fill="currentColor" fill-opacity="0.04" />
				<rect x="35" y="36" width="40" height="120" rx="3" />
				<text x="55" y="72" font-size="10" fill="currentColor" stroke="none" font-family="monospace" text-anchor="middle" opacity="0.4">$$$</text>
				<text x="55" y="100" font-size="10" fill="currentColor" stroke="none" font-family="monospace" text-anchor="middle" opacity="0.3">$$$</text>
				<text x="55" y="128" font-size="10" fill="currentColor" stroke="none" font-family="monospace" text-anchor="middle" opacity="0.2">$$$</text>
			</g>
			{/* Strikethrough (on hover) */}
			<line class="p7-strike" x1="30" y1="96" x2="80" y2="96" stroke-width="2.5" />
			{/* BYOK column */}
			<g class="p7-byok">
				<text x="145" y="28" font-size="7" fill="currentColor" stroke="none" font-family="monospace" text-anchor="middle" opacity="0.5">BYOK</text>
				<rect x="125" y="116" width="40" height="40" rx="3" fill="currentColor" fill-opacity="0.04" />
				<rect x="125" y="116" width="40" height="40" rx="3" stroke-width="2" />
				<text x="145" y="142" font-size="10" fill="currentColor" stroke="none" font-family="monospace" text-anchor="middle">$</text>
			</g>
			{/* Savings badge (on hover) */}
			<g class="p7-savings">
				<rect x="70" y="168" width="60" height="20" rx="4" stroke-width="1.5" />
				<text x="100" y="181" font-size="7" fill="currentColor" stroke="none" font-family="monospace" text-anchor="middle">−90% cost</text>
			</g>
		</svg>
	)}

	{order === 8 && (
		<svg viewBox="0 0 200 200" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="pillar-svg">
			{/* Actionability: hover applies the code fix */}
			{/* File frame */}
			<rect x="30" y="20" width="140" height="128" rx="4" stroke-width="1" />
			<line x1="30" y1="36" x2="170" y2="36" stroke-width="0.5" />
			<line x1="50" y1="36" x2="50" y2="148" stroke-width="0.3" opacity="0.15" />
			{/* Deletion lines */}
			<g class="p8-del">
				<rect x="30" y="42" width="140" height="14" fill="currentColor" fill-opacity="0.04" />
				<text x="37" y="52" font-size="6" fill="currentColor" stroke="none" font-family="monospace" opacity="0.4">−</text>
				<line x1="54" y1="49" x2="142" y2="49" stroke-width="0.8" opacity="0.3" />
			</g>
			<g class="p8-del">
				<rect x="30" y="56" width="140" height="14" fill="currentColor" fill-opacity="0.04" />
				<text x="37" y="66" font-size="6" fill="currentColor" stroke="none" font-family="monospace" opacity="0.4">−</text>
				<line x1="54" y1="63" x2="128" y2="63" stroke-width="0.8" opacity="0.3" />
			</g>
			<g class="p8-del">
				<rect x="30" y="70" width="140" height="14" fill="currentColor" fill-opacity="0.04" />
				<text x="37" y="80" font-size="6" fill="currentColor" stroke="none" font-family="monospace" opacity="0.4">−</text>
				<line x1="54" y1="77" x2="152" y2="77" stroke-width="0.8" opacity="0.3" />
			</g>
			{/* Separator */}
			<line x1="52" y1="91" x2="130" y2="91" stroke-width="0.5" opacity="0.1" />
			{/* Addition lines */}
			<g class="p8-add p8-a1">
				<rect x="30" y="98" width="140" height="14" fill="currentColor" fill-opacity="0.06" rx="0" />
				<text x="37" y="108" font-size="6" fill="currentColor" stroke="none" font-family="monospace">+</text>
				<line x1="54" y1="105" x2="148" y2="105" stroke-width="0.8" opacity="0.4" />
			</g>
			<g class="p8-add p8-a2">
				<rect x="30" y="112" width="140" height="14" fill="currentColor" fill-opacity="0.06" />
				<text x="37" y="122" font-size="6" fill="currentColor" stroke="none" font-family="monospace">+</text>
				<line x1="54" y1="119" x2="135" y2="119" stroke-width="0.8" opacity="0.4" />
			</g>

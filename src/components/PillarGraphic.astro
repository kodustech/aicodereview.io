---
interface Props {
	order: number;
}

const { order } = Astro.props;
---

<div class="w-full aspect-video md:aspect-[4/3] bg-stone-100 dark:bg-zinc-900 border border-stone-200 dark:border-zinc-800 flex items-center justify-center overflow-hidden text-stone-900 dark:text-zinc-100 relative">
	<!-- Background Grid -->
	<div class="absolute inset-0 opacity-10 dark:opacity-[0.05]" style="background-image: radial-gradient(currentColor 1px, transparent 1px); background-size: 16px 16px;"></div>

	{order === 1 && (
		<svg width="200" height="200" viewBox="0 0 200 200" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="relative z-10">
			<!-- Multi-dimensional Context: Nodes connecting to center -->
			<circle cx="100" cy="100" r="12">
				<animate attributeName="r" values="12;16;12" dur="3s" repeatCount="indefinite" />
			</circle>
			<g opacity="0.6">
				<circle cx="40" cy="60" r="4" />
				<circle cx="160" cy="40" r="4" />
				<circle cx="170" cy="150" r="4" />
				<circle cx="50" cy="160" r="4" />
				
				<path d="M 40 60 L 100 100">
					<animate attributeName="stroke-dasharray" values="0,100;100,0" dur="2s" repeatCount="indefinite" />
				</path>
				<path d="M 160 40 L 100 100" stroke-dasharray="4 4">
					<animate attributeName="stroke-dashoffset" values="0;8" dur="1s" repeatCount="indefinite" />
				</path>
				<path d="M 170 150 L 100 100">
					<animate attributeName="stroke-dasharray" values="0,100;100,0" dur="2.5s" repeatCount="indefinite" />
				</path>
				<path d="M 50 160 L 100 100" stroke-dasharray="4 4">
					<animate attributeName="stroke-dashoffset" values="8;0" dur="1.5s" repeatCount="indefinite" />
				</path>
			</g>
			<!-- Orbital ring -->
			<circle cx="100" cy="100" r="60" stroke-dasharray="2 6" opacity="0.3">
				<animateTransform attributeName="transform" type="rotate" from="0 100 100" to="360 100 100" dur="20s" repeatCount="indefinite" />
			</circle>
		</svg>
	)}

	{order === 2 && (
		<svg width="200" height="200" viewBox="0 0 200 200" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="square" class="relative z-10">
			<!-- Rule-Centric: Rigid filter/sieve -->
			<g opacity="0.3">
				<path d="M 20 40 L 180 40 M 20 80 L 180 80 M 20 120 L 180 120 M 20 160 L 180 160" />
			</g>
			<rect x="70" y="30" width="60" height="140" fill="currentColor" fill-opacity="0.1">
				<animate attributeName="y" values="30;35;30" dur="4s" repeatCount="indefinite" />
			</rect>
			<path d="M 70 30 L 130 30 M 70 170 L 130 170" stroke-width="2" />
			<!-- Good signals passing through -->
			<circle cx="100" cy="20" r="3" fill="currentColor">
				<animate attributeName="cy" values="20;180" dur="2s" repeatCount="indefinite" />
				<animate attributeName="opacity" values="1;1;0" dur="2s" repeatCount="indefinite" />
			</circle>
			<circle cx="85" cy="50" r="3" fill="currentColor">
				<animate attributeName="cy" values="50;180" dur="2.5s" repeatCount="indefinite" />
				<animate attributeName="opacity" values="1;1;0" dur="2.5s" repeatCount="indefinite" />
			</circle>
			<!-- Bad signals blocked -->
			<line x1="50" y1="20" x2="50" y2="40" stroke="currentColor">
				<animate attributeName="y2" values="40;40;20" dur="3s" repeatCount="indefinite" />
			</line>
			<line x1="150" y1="20" x2="150" y2="40" stroke="currentColor">
				<animate attributeName="y2" values="40;40;20" dur="2.2s" repeatCount="indefinite" />
			</line>
		</svg>
	)}

	{order === 3 && (
		<svg width="200" height="200" viewBox="0 0 200 200" fill="none" stroke="currentColor" stroke-width="1.5" class="relative z-10">
			<!-- Dual-Workflow: Two intersecting loops -->
			<!-- Fast Loop (Local) -->
			<path d="M 60 100 C 60 60, 100 60, 100 100 C 100 140, 60 140, 60 100 Z" stroke-dasharray="4 4" opacity="0.6">
				<animateTransform attributeName="transform" type="rotate" from="0 80 100" to="-360 80 100" dur="8s" repeatCount="indefinite" />
			</path>
			<!-- Slow/Guarded Loop (PR) -->
			<path d="M 140 100 C 140 40, 80 40, 80 100 C 80 160, 140 160, 140 100 Z" stroke-width="2">
				<animateTransform attributeName="transform" type="rotate" from="0 110 100" to="360 110 100" dur="15s" repeatCount="indefinite" />
			</path>
			<!-- Sync point -->
			<rect x="95" y="95" width="10" height="10" fill="currentColor" fill-opacity="0.2">
				<animate attributeName="transform" type="scale" values="1;1.2;1" from="100 100" to="100 100" dur="2s" repeatCount="indefinite" />
			</rect>
		</svg>
	)}

	{order === 4 && (
		<svg width="200" height="200" viewBox="0 0 200 200" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="relative z-10">
			<!-- Business Logic: Ticket merges with Code -->
			<g opacity="0.4">
				<!-- Ticket Shape -->
				<rect x="40" y="60" width="40" height="50" />
				<line x1="50" y1="75" x2="70" y2="75" />
				<line x1="50" y1="85" x2="60" y2="85" />
			</g>
			<!-- Code Brackets -->
			<path d="M 150 70 L 130 90 L 150 110" />
			<path d="M 170 70 L 190 90 L 170 110" />
			
			<!-- Connection/Validation Line -->
			<path d="M 80 85 L 120 85" stroke-dasharray="2 4">
				<animate attributeName="stroke-dashoffset" values="6;0" dur="1s" repeatCount="indefinite" />
			</path>
			<!-- Checkmark inside brackets appearing -->
			<path d="M 145 90 L 155 100 L 175 75" opacity="0">
				<animate attributeName="opacity" values="0;1;1;0" dur="4s" repeatCount="indefinite" />
			</path>
		</svg>
	)}

	{order === 5 && (
		<svg width="200" height="200" viewBox="0 0 200 200" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="relative z-10">
			<!-- Continuous Learning: Feedback Loop / Infinity -->
			<path d="M 50 100 C 50 50, 150 50, 150 100 C 150 150, 50 150, 50 100" opacity="0.3" />
			<path d="M 50 100 C 50 50, 150 50, 150 100 C 150 150, 50 150, 50 100" stroke-dasharray="314" stroke-dashoffset="314">
				<animate attributeName="stroke-dashoffset" values="314;0" dur="3s" repeatCount="indefinite" />
			</path>
			<!-- Arrow heads on the loop -->
			<path d="M 140 100 L 150 110 L 160 100" />
			<path d="M 40 100 L 50 90 L 60 100" />
			<!-- Brain/Memory node in center -->
			<circle cx="100" cy="100" r="15" fill="currentColor" fill-opacity="0.1">
				<animate attributeName="r" values="15;18;15" dur="1.5s" repeatCount="indefinite" />
			</circle>
		</svg>
	)}

	{order === 6 && (
		<svg width="200" height="200" viewBox="0 0 200 200" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="relative z-10">
			<!-- Sandbox Validation: Container holding a chaotic element -->
			<rect x="50" y="50" width="100" height="100" rx="4" stroke-width="2" />
			<path d="M 40 40 L 60 60 M 160 40 L 140 60 M 40 160 L 60 140 M 160 160 L 140 140" opacity="0.3" />
			<!-- Chaos inside -->
			<path d="M 80 80 L 120 120 M 120 80 L 80 120" stroke-width="1.5">
				<animateTransform attributeName="transform" type="translate" values="0 0; 5 -5; -5 5; 0 0" dur="0.2s" repeatCount="indefinite" />
			</path>
			<!-- Validation Scan Line -->
			<line x1="50" y1="50" x2="150" y2="50" stroke="currentColor" stroke-dasharray="2 2" opacity="0.5">
				<animate attributeName="y1" values="50;150;50" dur="4s" repeatCount="indefinite" />
				<animate attributeName="y2" values="50;150;50" dur="4s" repeatCount="indefinite" />
			</line>
		</svg>
	)}

	{order === 7 && (
		<svg width="200" height="200" viewBox="0 0 200 200" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="relative z-10">
			<!-- Economic Transparency: Layered blocks / Clear costs -->
			<g opacity="0.4">
				<path d="M 40 140 L 160 140" />
				<path d="M 40 100 L 160 100" />
				<path d="M 40 60 L 160 60" />
			</g>
			<!-- Zero Markup highlighting -->
			<rect x="60" y="100" width="20" height="40" fill="currentColor" fill-opacity="0.1">
				<animate attributeName="height" values="40;20;40" dur="3s" repeatCount="indefinite" />
				<animate attributeName="y" values="100;120;100" dur="3s" repeatCount="indefinite" />
			</rect>
			<rect x="120" y="60" width="20" height="80" fill="currentColor" fill-opacity="0.2">
				<animate attributeName="height" values="80;90;80" dur="4s" repeatCount="indefinite" />
				<animate attributeName="y" values="60;50;60" dur="4s" repeatCount="indefinite" />
			</rect>
			<!-- Eye / Visibility -->
			<path d="M 80 50 C 90 40, 110 40, 120 50 C 110 60, 90 60, 80 50 Z" />
			<circle cx="100" cy="50" r="3" fill="currentColor" />
		</svg>
	)}

	{order === 8 && (
		<svg width="200" height="200" viewBox="0 0 200 200" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="relative z-10">
			<!-- Actionability: One-click commit / Fix generation -->
			<path d="M 40 80 L 160 80" opacity="0.3" stroke-dasharray="4 4" />
			<!-- Code Block to be replaced -->
			<rect x="50" y="50" width="100" height="20" fill="currentColor" fill-opacity="0.1">
				<animate attributeName="opacity" values="0.1;0;0.1" dur="2s" repeatCount="indefinite" />
			</rect>
			<!-- The Fix Block -->
			<rect x="50" y="90" width="100" height="20" fill="currentColor" opacity="0">
				<animate attributeName="opacity" values="0;1;1;0" dur="4s" repeatCount="indefinite" />
			</rect>
			<!-- Arrow down / Action -->
			<path d="M 100 40 L 100 130 M 90 120 L 100 130 L 110 120" stroke-width="2">
				<animate attributeName="stroke-dasharray" values="0,100;100,0" dur="2s" repeatCount="indefinite" />
			</path>
			<!-- Checkmark -->
			<path d="M 90 150 L 95 160 L 115 140" stroke-width="2" opacity="0">
				<animate attributeName="opacity" values="0;1;1;0" dur="4s" repeatCount="indefinite" />
			</path>
		</svg>
	)}

	{order === 9 && (
		<svg width="200" height="200" viewBox="0 0 200 200" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="relative z-10">
			<!-- Measurable ROI: Observability Dashboard / Charts -->
			<g opacity="0.3">
				<path d="M 30 170 L 170 170" />
				<path d="M 30 170 L 30 30" />
			</g>
			<!-- Line Chart growing -->
			<path d="M 40 150 L 80 110 L 120 130 L 160 60" stroke-width="2">
				<animate attributeName="stroke-dasharray" values="0,200;200,0" dur="3s" repeatCount="indefinite" />
			</path>
			<!-- Bar Chart columns -->
			<rect x="50" y="120" width="15" height="50" fill="currentColor" fill-opacity="0.1">
				<animate attributeName="height" values="0;50" dur="1s" fill="freeze" />
				<animate attributeName="y" values="170;120" dur="1s" fill="freeze" />
			</rect>
			<rect x="90" y="80" width="15" height="90" fill="currentColor" fill-opacity="0.1">
				<animate attributeName="height" values="0;90" dur="1.5s" fill="freeze" />
				<animate attributeName="y" values="170;80" dur="1.5s" fill="freeze" />
			</rect>
			<rect x="130" y="40" width="15" height="130" fill="currentColor" fill-opacity="0.2">
				<animate attributeName="height" values="0;130" dur="2s" fill="freeze" />
				<animate attributeName="y" values="170;40" dur="2s" fill="freeze" />
			</rect>
			<!-- Target Point -->
			<circle cx="160" cy="60" r="4" fill="currentColor">
				<animate attributeName="r" values="4;6;4" dur="2s" repeatCount="indefinite" />
			</circle>
		</svg>
	)}
</div>